{
  "name": "apple-numbers-mcp",
  "version": "0.3.0",
  "description": "MCP server for reading and writing Apple Numbers (.numbers) spreadsheet files",
  "type": "module",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "bin": {
    "apple-numbers-mcp": "build/index.js"
  },
  "files": [
    "build",
    "src/utils/numbers_reader.py",
    "scripts/setup.sh",
    "requirements.txt",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "build": "tsc && tsc-alias",
    "start": "node build/index.js",
    "dev": "tsc --watch",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run src/__tests__/integration/",
    "test:all": "vitest run",
    "test:watch": "vitest",
    "version": "node -e \"const p=require('./package.json'); const f='.claude-plugin/plugin.json'; const c=JSON.parse(require('fs').readFileSync(f,'utf8')); c.version=p.version; require('fs').writeFileSync(f,JSON.stringify(c,null,2)+'\\n')\" && git add .claude-plugin/plugin.json",
    "prepublishOnly": "npm run lint && npm run test && npm run build",
    "prepare": "husky && npm run build"
  },
  "volta": {
    "node": "22.13.1"
  },
  "keywords": [
    "mcp",
    "apple-numbers",
    "claude",
    "ai",
    "spreadsheet",
    "macos",
    "numbers-parser",
    "model-context-protocol"
  ],
  "author": "Rob Sweet <rob@superiortech.io>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sweetrb/apple-numbers-mcp.git"
  },
  "homepage": "https://github.com/sweetrb/apple-numbers-mcp#readme",
  "bugs": {
    "url": "https://github.com/sweetrb/apple-numbers-mcp/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "os": [
    "darwin"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.4.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.0.0",
    "tsc-alias": "^1.8.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
